# ── Supabase (Auth + Postgres) ──────────────────────────────────────────────
# Project Settings → API. The VITE_-prefixed pair ships to the browser (safe:
# anon key + RLS). The un-prefixed pair is for server routes (api/*).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Service-role key — used by `npm run seed:owner` AND (as of per-user Strava/Oura)
# by the server routes that write encrypted OAuth tokens to oauth_connections.
# MUST now be set in Vercel (Production + Preview). Server-only, never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Encryption key for third-party OAuth tokens (Strava/Oura) stored at rest in
# oauth_connections. Any random 32+ char string. Generate with: openssl rand -base64 32
# MUST be set in Vercel (Production + Preview). Server-only, never prefix with VITE_.
# Note: changing this later makes every stored token undecryptable → users reconnect.
TOKEN_ENCRYPTION_KEY=replace_with_a_random_32_plus_character_string

# Owner account created by the seed script
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=choose_a_strong_password

# Upstash Redis (legacy store) — only needed by the seed script to pull the
# pre-multi-user completion/strength/swaps data. Copy from Vercel env vars.
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your_kv_token

# GitHub Actions secret (not a local var): SUPABASE_DB_URL = the Session
# pooler connection string, for the nightly db-backup workflow.

# Oura OAuth — get these from https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=your_client_id_here
OURA_CLIENT_SECRET=your_client_secret_here

# The exact redirect URI registered in your Oura app settings.
# Must match character-for-character (no trailing slash).
# Local dev: use http://localhost:5173/api/oura/callback
# Production: https://your-project.vercel.app/api/oura/callback
OURA_REDIRECT_URI=https://your-project.vercel.app/api/oura/callback

# Session encryption key — must be 32+ chars. Generate with: openssl rand -base64 32
SESSION_PASSWORD=replace_with_a_random_32_plus_character_string

# Anthropic — https://console.anthropic.com (server-side only, never use VITE_ prefix)
ANTHROPIC_API_KEY=sk-ant-...

# Strava OAuth — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Local dev: http://localhost:5173/api/strava/callback
# Production: https://your-project.vercel.app/api/strava/callback
STRAVA_REDIRECT_URI=https://your-project.vercel.app/api/strava/callback
